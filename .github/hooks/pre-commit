#!/usr/bin/env bash
# Pre-commit hook: Security and quality checks ONLY
# Workflow validation is handled by pre-handoff validation (.github/scripts/validate-handoff.sh)
# Issue reference validation is handled by commit-msg hook

echo "[INFO] Running pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

FAILED=0

echo ""
echo -e "${BLUE}-------------------------------------------------------${NC}"
echo -e "${BLUE}Security & Quality Checks${NC}"
echo -e "${BLUE}-------------------------------------------------------${NC}"
echo ""

# Check 1: No secrets in staged files (exclude .md docs - they contain example patterns)
echo -n "Checking for secrets... "
if git diff --cached --name-only | grep -v '\.md$' | xargs grep -E '(password|api[_-]?key|secret|token|private[_-]?key)\s*=\s*["\x27][^"\x27]+["\x27]' -i 2>/dev/null; then
 echo -e "${RED}[FAIL] FAILED${NC}"
 echo " Found potential secrets in staged files!"
 echo " Use environment variables instead."
 FAILED=1
else
 echo -e "${GREEN}[PASS] PASSED${NC}"
fi

# Check 2: No large files (>1MB)
echo -n "Checking file sizes... "
LARGE_FILES=$(git diff --cached --name-only | xargs ls -l 2>/dev/null | awk '$5 > 1048576 {print $9}')
if [ -n "$LARGE_FILES" ]; then
 echo -e "${YELLOW}[WARN] WARNING${NC}"
 echo " Large files detected (>1MB):"
 echo "$LARGE_FILES" | sed 's/^/ /'
else
 echo -e "${GREEN}[PASS] PASSED${NC}"
fi

# Check 3: Warn on direct master/main commits
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
 echo -e "${YELLOW}[WARN] WARNING: Committing directly to $BRANCH${NC}"
fi

# Check 4: C# formatting (if dotnet available)
if command -v dotnet &> /dev/null; then
 CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$')
 if [ -n "$CS_FILES" ]; then
 echo -n "Checking C# formatting... "
 if dotnet format --verify-no-changes --include $CS_FILES &>/dev/null; then
 echo -e "${GREEN}[PASS] PASSED${NC}"
 else
 echo -e "${YELLOW}[WARN] Auto-formatting${NC}"
 dotnet format --include $CS_FILES
 echo "$CS_FILES" | xargs git add
 fi
 fi
fi

# Check 5: Python formatting (if black available)
if command -v black &> /dev/null; then
 PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')
 if [ -n "$PY_FILES" ]; then
 echo -n "Checking Python formatting... "
 if black --check $PY_FILES &>/dev/null; then
 echo -e "${GREEN}[PASS] PASSED${NC}"
 else
 echo -e "${YELLOW}[WARN] Auto-formatting${NC}"
 black $PY_FILES
 echo "$PY_FILES" | xargs git add
 fi
 fi
fi

# Check 6: SQL injection patterns
echo -n "Checking for SQL injection risks... "
if git diff --cached | grep -E '\+.*\b(ExecuteRaw|FromSqlRaw|SqlQuery).*\+' | grep -v 'parameterized' | grep -v '@' &>/dev/null; then
 echo -e "${YELLOW}[WARN] WARNING: Potential SQL injection${NC}"
else
 echo -e "${GREEN}[PASS] PASSED${NC}"
fi

# Check 7: Command allowlist validation (scan all staged code changes, not just new files)
echo -n "Checking for blocked commands... "
BLOCKED_COMMANDS=("rm -rf" "git reset --hard" "git push --force" "DROP DATABASE" "DROP TABLE" "TRUNCATE" "format c:" "del /s" "rmdir /s")
BLOCKED_FOUND=0
CHANGED_CODE_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -v '\.md$' | grep -v '\.test\.ts$' | grep -v '\.test\.js$' | grep -v '\.spec\.ts$' | grep -v '\.spec\.js$' | grep -v 'commandValidator' | grep -v '\.github/hooks/' | grep -v 'agentx-security\.yml' | grep -v 'agentic-runner\.ps1' | grep -v 'install\.sh')

if [ -n "$CHANGED_CODE_FILES" ]; then
 for cmd in "${BLOCKED_COMMANDS[@]}"; do
  if echo "$CHANGED_CODE_FILES" | xargs grep -F "$cmd" 2>/dev/null; then
   echo -e "${RED}[FAIL] BLOCKED COMMAND: $cmd${NC}"
   BLOCKED_FOUND=1
  fi
 done
fi

if [ $BLOCKED_FOUND -eq 0 ]; then
 echo -e "${GREEN}[PASS] PASSED${NC}"
else
 echo -e "${RED}[FAIL] Blocked destructive command found${NC}"
 echo " Review .github/security/allowed-commands.json for allowed operations"
 FAILED=1
fi

# Summary
echo ""

# ---------------------------------------------------------------
# Check 8: Quality loop enforcement
# All source code commits require a completed, non-consumed loop.
# - Active loop: block immediately (iteration in progress).
# - No loop or non-complete: block when code files are staged.
# - Consumed loop (committed without renewal): block for code changes.
# - Emergency bypass: AGENTX_SKIP_LOOP_GATE=1 (hotfixes only).
# ---------------------------------------------------------------
LOOP_STATE=".agentx/state/loop-state.json"
LOOP_ACTIVE=""
LOOP_STATUS=""
LOOP_CONSUMED=""
LOOP_ITERATION=0
LOOP_MIN_ITERATIONS=0
LOOP_HAS_REVIEW_ITERATION=""
if [ -f "$LOOP_STATE" ]; then
  LOOP_ACTIVE=$(grep -o '"active":[[:space:]]*true' "$LOOP_STATE" 2>/dev/null || true)
  LOOP_STATUS=$(grep -o '"status":[[:space:]]*"[^"]*"' "$LOOP_STATE" 2>/dev/null | head -1 | sed 's/"status":[[:space:]]*"//' | sed 's/"//')
  LOOP_CONSUMED=$(grep -o '"loopConsumed":[[:space:]]*true' "$LOOP_STATE" 2>/dev/null || true)
  # Top-level iteration counter (first match -- nested history entries follow it)
  LOOP_ITERATION=$(grep -oE '"iteration":[[:space:]]*[0-9]+' "$LOOP_STATE" 2>/dev/null | head -1 | grep -oE '[0-9]+')
  LOOP_MIN_ITERATIONS=$(grep -oE '"minIterations":[[:space:]]*[0-9]+' "$LOOP_STATE" 2>/dev/null | head -1 | grep -oE '[0-9]+')
  # Subagent review marker: any history summary mentioning "review" (case-insensitive)
  LOOP_HAS_REVIEW_ITERATION=$(grep -iE '"summary":[[:space:]]*"[^"]*\b(reviewer|sub-?agent[^"]*review|subagent[^"]*review|review[^"]*pass|review[^"]*loop)' "$LOOP_STATE" 2>/dev/null | head -1)
  : "${LOOP_ITERATION:=0}"
  : "${LOOP_MIN_ITERATIONS:=0}"
fi

# Block active loops first (regardless of file type)
if [ -n "$LOOP_ACTIVE" ]; then
  echo -e "${RED}[FAIL] Quality loop still ACTIVE (iteration in progress)${NC}"
  echo "  Complete the loop before committing: agentx loop complete -s <summary>"
  echo "  Or cancel if needed: agentx loop cancel"
  FAILED=1
elif [ "$LOOP_STATUS" = "cancelled" ]; then
  echo -e "${YELLOW}[WARN] Quality loop was cancelled (does not satisfy quality gate)${NC}"
  echo "  Start and complete a new loop for handoff eligibility."
elif [ "$LOOP_STATUS" = "complete" ] && [ -z "$LOOP_CONSUMED" ]; then
  echo -e "${GREEN}[PASS] Quality loop completed${NC}"
elif [ "$LOOP_STATUS" = "complete" ] && [ -n "$LOOP_CONSUMED" ]; then
  echo -e "${YELLOW}[WARN] Quality loop was consumed by a prior commit (requires renewal for code changes)${NC}"
fi

# Require a completed, non-consumed loop for any source code file commits.
# This closes two enforcement gaps:
#   1. Code changes committed with no loop started at all.
#   2. Code changes committed using a stale "complete" loop from a prior task.
# Active-loop failures are already reported above, so skip re-reporting.
CODE_FILES_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|mjs|cjs|ps1|psm1|psd1|py|pyx|cs|csx|go|rs|sh|bash|tf|tfvars|bicep|sql)$' | head -1)
if [ -n "$CODE_FILES_STAGED" ] && [ -z "$LOOP_ACTIVE" ]; then
  LOOP_GATE_FAIL=0
  LOOP_GATE_MSG=""
  if [ "$LOOP_STATUS" != "complete" ]; then
    LOOP_GATE_FAIL=1
    LOOP_GATE_MSG="Code files staged but no completed quality loop found"
  elif [ -n "$LOOP_CONSUMED" ]; then
    LOOP_GATE_FAIL=1
    LOOP_GATE_MSG="Quality loop was already consumed by a prior commit -- start a fresh loop"
  elif [ "${LOOP_MIN_ITERATIONS:-0}" -gt 0 ] && [ "${LOOP_ITERATION:-0}" -lt "${LOOP_MIN_ITERATIONS:-0}" ]; then
    LOOP_GATE_FAIL=1
    LOOP_GATE_MSG="Quality loop completed below minimum iterations: $LOOP_ITERATION/$LOOP_MIN_ITERATIONS -- run more 'agentx loop iterate' passes"
  elif [ -z "$LOOP_HAS_REVIEW_ITERATION" ]; then
    LOOP_GATE_FAIL=1
    LOOP_GATE_MSG="Quality loop missing subagent reviewer pass -- at least one iteration summary MUST contain 'review' (e.g. 'Iter N (Subagent Review): ...')"
  fi
  if [ $LOOP_GATE_FAIL -eq 1 ]; then
    if [ -z "$AGENTX_SKIP_LOOP_GATE" ]; then
      echo -e "${RED}[FAIL] $LOOP_GATE_MSG${NC}"
      echo "  ALL code changes MUST be wrapped in a completed quality loop with subagent review:"
      echo "    agentx loop start -p \"<task description>\""
      echo "    agentx loop iterate -s \"<progress summary>\" -e <evidence-file>   # repeat >= minIterations"
      echo "    agentx loop iterate -s \"Subagent Review: <findings>\" -e <review-evidence>"
      echo "    agentx loop complete -s \"All gates passed\" -e <final-gate-evidence>"
      echo "  Emergency hotfix bypass: AGENTX_SKIP_LOOP_GATE=1 git commit"
      FAILED=1
    else
      echo -e "${YELLOW}[WARN] Loop gate bypassed (AGENTX_SKIP_LOOP_GATE -- emergency use only)${NC}"
    fi
  fi
fi

# ---------------------------------------------------------------
# Check 9: Review document requires completed loop
# Block commits of review artifacts when no completed loop exists.
# Catches agents that skip loop start entirely.
# ---------------------------------------------------------------
REVIEW_DOCS=$(git diff --cached --name-only | grep '^docs/artifacts/reviews/.*\.md$')
if [ -n "$REVIEW_DOCS" ]; then
  LOOP_COMPLETE=0
  if [ -f "$LOOP_STATE" ]; then
    LOOP_STATUS_CHECK=$(grep -o '"status":[[:space:]]*"[^"]*"' "$LOOP_STATE" 2>/dev/null | head -1 | sed 's/"status":[[:space:]]*"//' | sed 's/"//')
    if [ "$LOOP_STATUS_CHECK" = "complete" ]; then
      LOOP_COMPLETE=1
    fi
  fi
  if [ $LOOP_COMPLETE -eq 0 ]; then
    echo -e "${RED}[FAIL] Review document staged but quality loop not completed${NC}"
    echo "  Review agents MUST run the quality loop before committing:"
    echo "    agentx loop start -p \"Reviewing: <description>\""
    echo "    ... (verify, self-review, iterate)"
    echo "    agentx loop complete -s \"All quality gates passed\""
    FAILED=1
  else
    echo -e "${GREEN}[PASS] Review document has completed quality loop${NC}"
  fi
fi

# ---------------------------------------------------------------
# Check 10: Learning capture file structure validation
# Validates LEARNING-*.md files have required sections.
# Catches incomplete compound capture artifacts before they land.
# ---------------------------------------------------------------
LEARNING_FILES=$(git diff --cached --name-only | grep '^docs/artifacts/learnings/LEARNING-.*\.md$')
if [ -n "$LEARNING_FILES" ]; then
  for LEARNING_FILE in $LEARNING_FILES; do
    if [ -f "$LEARNING_FILE" ]; then
      LEARNING_OK=1
      # Must reference an issue number
      if ! grep -qE '#[0-9]+|issue|Issue' "$LEARNING_FILE" 2>/dev/null; then
        echo -e "${YELLOW}[WARN] Learning capture missing issue reference: $LEARNING_FILE${NC}"
        echo "  Add a reference to the originating issue (e.g. #42)."
        LEARNING_OK=0
      fi
      # Must have a review/source link section
      if ! grep -qiE 'review|source|origin' "$LEARNING_FILE" 2>/dev/null; then
        echo -e "${YELLOW}[WARN] Learning capture missing review/source link: $LEARNING_FILE${NC}"
        echo "  Link back to the review artifact that makes this learning trustworthy."
        LEARNING_OK=0
      fi
      if [ $LEARNING_OK -eq 1 ]; then
        echo -e "${GREEN}[PASS] Learning capture structure valid: $LEARNING_FILE${NC}"
      fi
    fi
  done
fi

# ---------------------------------------------------------------
# Check 11: Compound Capture gate (HARD FAIL)
# Approved review staged -> matching LEARNING-<issue>.md MUST also be staged,
# OR commit message includes [skip-capture] token with rationale.
# ---------------------------------------------------------------
COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"
COMMIT_MSG_CONTENT=""
if [ -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG_CONTENT=$(cat "$COMMIT_MSG_FILE" 2>/dev/null)
fi

APPROVED_REVIEWS=$(git diff --cached --name-only | grep '^docs/artifacts/reviews/REVIEW-.*\.md$')
if [ -n "$APPROVED_REVIEWS" ]; then
  for REVIEW_FILE in $APPROVED_REVIEWS; do
    if [ -f "$REVIEW_FILE" ] && grep -qiE 'APPROVED|approved|Approved' "$REVIEW_FILE" 2>/dev/null; then
      ISSUE_NUM=$(echo "$REVIEW_FILE" | grep -oE '[0-9]+' | head -1)
      if [ -n "$ISSUE_NUM" ]; then
        LEARNING_PATH="docs/artifacts/learnings/LEARNING-${ISSUE_NUM}.md"
        LEARNING_STAGED=$(git diff --cached --name-only | grep -F "$LEARNING_PATH")
        if [ -z "$LEARNING_STAGED" ]; then
          if echo "$COMMIT_MSG_CONTENT" | grep -qF '[skip-capture]'; then
            echo -e "${YELLOW}[WARN] Compound Capture bypassed via [skip-capture]: $REVIEW_FILE${NC}"
            echo "  Ensure the skip rationale is recorded in the issue close comment."
          else
            echo -e "${RED}[FAIL] Approved review staged without Compound Capture: $REVIEW_FILE${NC}"
            echo "  Resolve Compound Capture before declaring work Done:"
            echo "    Mandatory: stage $LEARNING_PATH (create from .github/templates/LEARNING-TEMPLATE.md if available)"
            echo "    Bypass:    add [skip-capture] to commit message AND record rationale in issue close comment"
            echo "  See docs/WORKFLOW.md#compound-capture for the full contract."
            FAILED=1
          fi
        else
          echo -e "${GREEN}[PASS] Learning capture staged for approved review: $LEARNING_PATH${NC}"
        fi
      fi
    fi
  done
fi

# ---------------------------------------------------------------
# Check 12: Deliverable structure validation (pipeline phase compliance)
# Validates key artifacts have required sections proving phases were completed.
# PRD: must have Problem Statement / Goals / Requirements sections.
# ADR: must evaluate at least 3 options.
# UX spec: must have a corresponding prototype file.
# ---------------------------------------------------------------

# PRD structure check
PRD_FILES=$(git diff --cached --name-only | grep '^docs/artifacts/prd/PRD-.*\.md$')
if [ -n "$PRD_FILES" ]; then
  for PRD in $PRD_FILES; do
    if [ -f "$PRD" ]; then
      if ! grep -qiE '##[[:space:]]*(Problem Statement|Goals|Requirements|Acceptance Criteria|User Stories)' "$PRD" 2>/dev/null; then
        echo -e "${YELLOW}[WARN] PRD missing required sections: $PRD${NC}"
        echo "  PRD MUST include: Problem Statement, Goals, Requirements, or Acceptance Criteria."
        echo "  Complete the Research phase before writing the PRD."
      else
        echo -e "${GREEN}[PASS] PRD structure valid: $PRD${NC}"
      fi
    fi
  done
fi

# ADR structure check -- must evaluate at least 3 options
ADR_FILES=$(git diff --cached --name-only | grep '^docs/artifacts/adr/ADR-.*\.md$')
if [ -n "$ADR_FILES" ]; then
  for ADR in $ADR_FILES; do
    if [ -f "$ADR" ]; then
      OPTION_COUNT=$(grep -ciE '###[[:space:]]*Option[[:space:]]+[0-9]|##[[:space:]]*Option[[:space:]]*[0-9]' "$ADR" 2>/dev/null)
      if [ -z "$OPTION_COUNT" ] || [ "$OPTION_COUNT" -lt 3 ] 2>/dev/null; then
        echo -e "${YELLOW}[WARN] ADR evaluates fewer than 3 options: $ADR${NC}"
        echo "  Architect MUST evaluate at least 3 options. Complete the research phase first."
      else
        echo -e "${GREEN}[PASS] ADR evaluates $OPTION_COUNT options: $ADR${NC}"
      fi
    fi
  done
fi

# UX spec check -- must have a corresponding prototype file
UX_SPEC_FILES=$(git diff --cached --name-only | grep '^docs/ux/UX-.*\.md$')
if [ -n "$UX_SPEC_FILES" ]; then
  for UX_SPEC in $UX_SPEC_FILES; do
    if [ -f "$UX_SPEC" ]; then
      ISSUE_NUM=$(echo "$UX_SPEC" | grep -oE '[0-9]+' | head -1)
      if [ -n "$ISSUE_NUM" ]; then
        PROTO_EXISTS=$(find docs/ux/prototypes -name "*${ISSUE_NUM}*" 2>/dev/null | head -1)
        if [ -z "$PROTO_EXISTS" ]; then
          echo -e "${YELLOW}[WARN] UX spec staged without a matching prototype: $UX_SPEC${NC}"
          echo "  UX Designer MUST create HTML/CSS prototypes at docs/ux/prototypes/ before handoff."
          echo "  Complete the HTML/CSS Prototypes phase before committing the UX spec."
        else
          echo -e "${GREEN}[PASS] UX prototype exists for spec: $PROTO_EXISTS${NC}"
        fi
      fi
    fi
  done
fi

# ---------------------------------------------------------------
# Check 13: Model Council gate (HARD FAIL)
# New ADR staged -> matching COUNCIL-*.md MUST also be staged,
# OR commit message includes [skip-council] token.
# The COUNCIL file must capture 3 diverse-model perspectives and a Synthesis section.
# ---------------------------------------------------------------
STAGED_ADRS=$(git diff --cached --name-only --diff-filter=A | grep '^docs/artifacts/adr/ADR-.*\.md$')
if [ -n "$STAGED_ADRS" ]; then
  for ADR_FILE in $STAGED_ADRS; do
    ADR_BASENAME=$(basename "$ADR_FILE" .md)
    ADR_ID=$(echo "$ADR_BASENAME" | sed 's/^ADR-//')
    COUNCIL_PATH="docs/artifacts/adr/COUNCIL-${ADR_ID}.md"
    COUNCIL_STAGED=$(git diff --cached --name-only | grep -F "$COUNCIL_PATH")
    if [ -z "$COUNCIL_STAGED" ]; then
      if echo "$COMMIT_MSG_CONTENT" | grep -qF '[skip-council]'; then
        echo -e "${YELLOW}[WARN] Model Council bypassed via [skip-council]: $ADR_FILE${NC}"
        echo "  Ensure the skip rationale is documented inside the ADR's Decision section."
      else
        echo -e "${RED}[FAIL] New ADR staged without matching Model Council: $ADR_FILE${NC}"
        echo "  Architect/PM/Data Scientist/Reviewer MUST convene a Model Council before landing a new ADR:"
        echo "    Mandatory: stage $COUNCIL_PATH with 3 diverse-model perspectives + Synthesis section"
        echo "    Helper:    pwsh scripts/model-council.ps1 -AdrId $ADR_ID"
        echo "    Bypass:    add [skip-council] to commit message AND document rationale in ADR Decision"
        echo "  See docs/WORKFLOW.md#model-council for the full contract."
        FAILED=1
      fi
    else
      if [ -f "$COUNCIL_PATH" ]; then
        if ! grep -qiE '^##+ *(Synthesis|Consensus|Conclusion)' "$COUNCIL_PATH" 2>/dev/null; then
          echo -e "${RED}[FAIL] Model Council file missing Synthesis section: $COUNCIL_PATH${NC}"
          echo "  COUNCIL files MUST include a '## Synthesis' section that resolves the 3 perspectives."
          FAILED=1
        else
          PERSPECTIVE_COUNT=$(grep -ciE '^##+ *(Model|Perspective|Opinion|Reviewer)[[:space:]]*[0-9A-Za-z]' "$COUNCIL_PATH" 2>/dev/null || echo 0)
          if [ "$PERSPECTIVE_COUNT" -lt 3 ] 2>/dev/null; then
            echo -e "${RED}[FAIL] Model Council has fewer than 3 model perspectives: $COUNCIL_PATH (found $PERSPECTIVE_COUNT)${NC}"
            echo "  COUNCIL files MUST capture at least 3 diverse-model perspectives."
            FAILED=1
          else
            echo -e "${GREEN}[PASS] Model Council valid ($PERSPECTIVE_COUNT perspectives + Synthesis): $COUNCIL_PATH${NC}"
          fi
        fi
      fi
    fi
  done
fi

# ---------------------------------------------------------------
# Check 14: Execution Plan gate (HARD FAIL)
# Commits changing >= 8 code files MUST stage a matching EXEC-PLAN-*.md,
# OR commit message includes [skip-plan] token.
# Code file extensions: .ts .tsx .js .jsx .ps1 .py .cs .go .rs .tf .bicep .sql .java .rb .php
# ---------------------------------------------------------------
CODE_FILES_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -cE '\.(ts|tsx|js|jsx|ps1|py|cs|go|rs|tf|bicep|sql|java|rb|php)$' 2>/dev/null || echo 0)
if [ "$CODE_FILES_CHANGED" -ge 8 ] 2>/dev/null; then
  PLAN_STAGED=$(git diff --cached --name-only | grep '^docs/execution/plans/EXEC-PLAN-.*\.md$' | head -1)
  if [ -z "$PLAN_STAGED" ]; then
    if echo "$COMMIT_MSG_CONTENT" | grep -qF '[skip-plan]'; then
      echo -e "${YELLOW}[WARN] Execution Plan bypassed via [skip-plan] ($CODE_FILES_CHANGED code files changed)${NC}"
      echo "  Confirm this is genuinely simple/mechanical work that does not need a plan."
    else
      echo -e "${RED}[FAIL] Complex commit ($CODE_FILES_CHANGED code files) without execution plan${NC}"
      echo "  Commits touching >= 8 code files MUST be backed by a living execution plan:"
      echo "    Mandatory: stage docs/execution/plans/EXEC-PLAN-<topic>.md (template: .github/templates/EXEC-PLAN-TEMPLATE.md)"
      echo "    Bypass:    add [skip-plan] to commit message (use only for trivial bulk edits)"
      echo "  See docs/WORKFLOW.md#execution-plans-for-complex-work for required plan sections."
      FAILED=1
    fi
  else
    echo -e "${GREEN}[PASS] Execution plan staged for complex commit ($CODE_FILES_CHANGED code files): $PLAN_STAGED${NC}"
  fi
fi

if [ $FAILED -eq 1 ]; then
 echo -e "${RED}[FAIL] Pre-commit checks FAILED${NC}"
 exit 1
else
 echo -e "${GREEN}[PASS] Security checks passed${NC}"
 exit 0
fi
