#!/usr/bin/env bash
# Commit-msg hook: Issue-First Workflow Validation
# Single source of truth for all workflow enforcement

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo ""
echo -e "${BLUE}-------------------------------------------------------${NC}"
echo -e "${BLUE}AgentX Workflow Validation${NC}"
echo -e "${BLUE}-------------------------------------------------------${NC}"
echo ""

# ===================================================================
# Mode detection: skip issue enforcement in local mode (opt-in via enforceIssues)
# ===================================================================
CONFIG_FILE=".agentx/config.json"
AGENTX_MODE="local"
ENFORCE_ISSUES="false"

if [ -f "$CONFIG_FILE" ]; then
 # Read mode from config (default: local)
 DETECTED_MODE=$(grep -o '"mode"\s*:\s*"[^"]*"' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*"mode"\s*:\s*"//' | sed 's/"//')
 if [ -n "$DETECTED_MODE" ]; then
  AGENTX_MODE="$DETECTED_MODE"
 fi
 # Read enforceIssues flag (default: false)
 DETECTED_ENFORCE=$(grep -o '"enforceIssues"\s*:\s*[a-z]*' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*:\s*//')
 if [ "$DETECTED_ENFORCE" = "true" ]; then
  ENFORCE_ISSUES="true"
 fi
fi

# In local mode, skip issue enforcement unless explicitly opted in
if [ "$AGENTX_MODE" = "local" ] && [ "$ENFORCE_ISSUES" != "true" ]; then
 # Still validate commit format (warning only)
 if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|test|refactor|perf|chore|style|build|ci):'; then
  echo -e "${YELLOW}[WARN] Commit format should be: type: description${NC}"
 fi
 echo -e "${GREEN}[PASS] Local mode - issue enforcement skipped${NC}"
 exit 0
fi

# Skip for merge commits, reverts, and initial commits
if echo "$COMMIT_MSG" | grep -qE '^(Merge|Revert|Initial commit)'; then
 echo -e "${GREEN}[PASS] Merge/Revert commit - skipping validation${NC}"
 exit 0
fi

# Skip if [skip-issue] in commit message (emergency only)
if echo "$COMMIT_MSG" | grep -qE '\[skip-issue\]'; then
 echo -e "${YELLOW}[WARN] WARNING: Skipping issue validation (emergency mode)${NC}"
 exit 0
fi

# ===================================================================
# STEP 1: Check for issue reference
# ===================================================================
echo -n "Checking for issue reference... "
if ! echo "$COMMIT_MSG" | grep -qE '#[0-9]+|((closes|fixes|resolves|refs?)\s+#[0-9]+)'; then
 echo -e "${RED}[FAIL] FAILED${NC}"
 echo ""
 echo "Your commit message must reference a GitHub Issue."
 echo ""
 echo -e " ${GREEN}Format:${NC} type: description (#123)"
 echo -e " ${GREEN}Example:${NC} feat: add user login (#42)"
 echo ""
 echo "To create an issue: gh issue create --web"
 echo ""
 echo "Emergency bypass: Add [skip-issue] to commit message"
 echo ""
 exit 1
fi

ISSUE_NUMBER=$(echo "$COMMIT_MSG" | grep -oP '#\K\d+' | head -1)
echo -e "${GREEN}[PASS] Found #${ISSUE_NUMBER}${NC}"

if ! echo "$COMMIT_MSG" | grep -qiE '\b(closes|fixes|resolves)\s+#[0-9]+'; then
 echo -e "${YELLOW}[WARN] Plain issue references do not auto-close GitHub issues${NC}"
 echo -e "${YELLOW}[WARN] Use fixes #${ISSUE_NUMBER}, closes #${ISSUE_NUMBER}, or resolves #${ISSUE_NUMBER} in the final PR or delivery commit${NC}"
fi

# ===================================================================
# STEP 2: Validate commit message format (warning only)
# ===================================================================
# Note: Workflow document validation moved to pre-handoff validation
# See: .github/scripts/validate-handoff.sh
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|test|refactor|perf|chore|style|build|ci):'; then
 echo -e "${YELLOW}[WARN] Commit format should be: type: description (#issue)${NC}"
fi

# ===================================================================
# STEP 3: fix: commits MUST add a regression test in the same diff
# Deterministic rule: a bug fix without a test cannot enter the repo.
# Bypass: AGENTX_SKIP_FIX_TEST_GATE=1 (use only when fix is provably untestable).
# ===================================================================
if echo "$COMMIT_MSG" | grep -qE '^fix(\([^)]+\))?:'; then
 # Source files that look like production code under change
 PROD_CHANGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
   | grep -E '^(\.agentx/|src/|lib/|app/|server/|services/|packages/|scripts/|vscode-extension/src/|install\.ps1$|install\.sh$)' \
   | grep -E '\.(ts|tsx|js|mjs|cjs|py|cs|go|rs|java|kt|rb|ps1|psm1)$' \
   | grep -vE '(\.test\.|\.spec\.|/tests?/|/__tests__/)' || true)
 if [ -n "$PROD_CHANGED" ]; then
  TEST_CHANGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '(\.test\.|\.spec\.|/tests?/|/__tests__/|test_.*\.py$|.*_test\.go$|.*Tests\.cs$)' || true)
  TEST_LINES_ADDED=0
  if [ -n "$TEST_CHANGED" ]; then
   TEST_LINES_ADDED=$(git diff --cached --diff-filter=ACM -- $TEST_CHANGED 2>/dev/null \
     | grep -cE '^\+[^+].*((it|test|describe)\(|def test_|\[Fact\]|\[Theory\]|func Test|@Test)' || true)
  fi
  if [ -z "$TEST_CHANGED" ] || [ "$TEST_LINES_ADDED" -lt 1 ]; then
   if [ -z "$AGENTX_SKIP_FIX_TEST_GATE" ]; then
    echo -e "${RED}[FAIL] fix: commit must include a new regression test in the same diff${NC}"
    echo "  Production files changed:"
    echo "$PROD_CHANGED" | sed 's/^/    /'
    echo "  Add a failing test that reproduces the bug, then fix."
    echo "  Bypass (rare): AGENTX_SKIP_FIX_TEST_GATE=1 git commit ..."
    exit 1
   else
    echo -e "${YELLOW}[WARN] fix-test gate bypassed (AGENTX_SKIP_FIX_TEST_GATE)${NC}"
   fi
  else
   echo -e "${GREEN}[PASS] fix: commit includes test changes${NC}"
  fi
 fi
fi

echo ""
echo -e "${GREEN}[PASS] Workflow validation passed${NC}"
exit 0
