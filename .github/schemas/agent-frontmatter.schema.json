{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "title": "AgentX Agent File Frontmatter",
 "description": "Schema for .agent.md frontmatter validation",
 "type": "object",
 "required": ["description"],
 "properties": {
  "description": {
   "type": "string",
   "minLength": 10,
   "maxLength": 500,
   "description": "Agent purpose and trigger conditions"
  },
  "model": {
   "type": "string",
   "description": "Preferred LLM model identifier"
  },
  "tools": {
   "type": "array",
   "items": { "type": "string" },
   "description": "Copilot tool names available to this agent"
  },
  "agents": {
   "type": "array",
   "items": { "type": "string" },
   "description": "Agent names this agent may spawn via runSubagent"
  },
  "handoffs": {
   "type": "array",
   "items": {
    "type": "object",
    "required": ["label", "agent"],
    "properties": {
     "label": { "type": "string" },
     "agent": { "type": "string" },
     "prompt": { "type": "string" },
     "send": { "type": "boolean" }
    }
   },
   "description": "Agent-to-agent handoff declarations"
  }
 },
 "additionalProperties": false
}
