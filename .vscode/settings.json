// AgentX Agents Window opt-in (Phase 2, CONTRACT-400-agents-window-slice2).
// Enables AgentX in the VS Code Agents Window for anyone who clones this repo
// and opens it in VS Code. The AgentX extension itself prompts every
// install/upgrade to set this globally; this entry is a courtesy for repo
// cloners so it works in the workspace without waiting for the prompt.
{
  "extensions.supportAgentsWindow": {
    "jnPiyush.agentx": true
  }
}